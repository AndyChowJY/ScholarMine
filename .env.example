# ScholarMine Environment Variables
# Copy this file to .env and fill in your credentials.
# .env is git-ignored — never commit real keys.

# DeepSeek API (required — used for all LLM calls)
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: fallback LLM providers
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Sci-Hub mirror (optional — for DOI-based PDF retrieval)
# Default mirrors are tried automatically; set a preferred one here
# SCIHUB_MIRROR=https://sci-hub.se

# Proxy settings (optional)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890